          <div>
            <h3 className="text-white font-semibold text-lg mb-4">Resources</h3>
            <ul className="space-y-2">
              {resources.map((resource) => (
                <li key={resource.name}>
                  <Link
                    href={resource.href}
                    className="text-gray-400 hover:text-red-500 text-sm transition-colors duration-300"
                  >
                    {resource.name}
                  </Link>
                </li>
              ))}
            </ul>
          </div>

          {/* Contact Info */}
          <div>
            <h3 className="text-white font-semibold text-lg mb-4">Get in Touch</h3>
            <div className="space-y-3">
              <div className="flex items-start gap-3">
                <MapPin size={16} className="text-red-500 mt-0.5 flex-shrink-0" />
                <span className="text-gray-400 text-sm">Kathmandu, Nepal</span>
              </div>
              <div className="flex items-center gap-3">
                <Phone size={16} className="text-red-500 flex-shrink-0" />
                <a href="tel:+9779800000000" className="text-gray-400 hover:text-red-500 text-sm transition-colors">
                  +977 980-000-0000
                </a>
              </div>
              <div className="flex items-center gap-3">
                <Globe size={16} className="text-red-500 flex-shrink-0" />
                <span className="text-gray-400 text-sm">www.devcommunitynepal.com</span>
              </div>
            </div>
          </div>
        </div>

        {/* Divider */}
        <div className="border-t border-white/10 my-8" />

        {/* Bottom Section */}
        <div className="flex flex-col md:flex-row justify-between items-center gap-4">
          {/* Social Links */}
          <div className="flex gap-4">
            {socialLinks.map((social) => (
              <motion.a
                key={social.name}
                href={social.href}
                whileHover={{ scale: 1.1, y: -2 }}
                className={`text-gray-400 ${social.color} transition-all duration-300`}
                aria-label={social.name}
              >
                {getSocialIcon(social.icon)}
              </motion.a>
            ))}
          </div>

          {/* Copyright */}
          <div className="text-center">
            <p className="text-gray-500 text-xs">
              © {currentYear} DEV Community Nepal. All rights reserved.
            </p>
            <p className="text-gray-600 text-xs mt-1">
              Made with <Heart size={10} className="inline text-red-500" /> in Nepal
